            <td>Completed</td>
        </tr>
    </table>
</section>

<hr>

<section id="contact">
    <h2>Contact Me</h2>
    <form>
        <label>Name:</label><br>
        <input type="text" name="name"><br><br>

        <label>Email:</label><br>
