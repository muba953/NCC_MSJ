        <li>Thermodynamics</li>
        <li>Fluid Mechanics</li>
    </ol>

    <h2>Education</h2>
    <table border="2">
        <tr>
            <th>Course Name</th>
            <th>Year</th>
            <th>Status</th>
        </tr>
        <tr>
            <td>Chemical Engineering</td>
