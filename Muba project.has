# style.css

/* Universal Selector */
* {
    margin: 0;
    padding: 0;
    font-family: Arial;
}

/* Element Selector */
body {
    background-color: rgb(194, 199, 194);
    text-align: center;   /* FIXED */
}

/* ID Selector */
#title {
    color: darkgreen;
    text-align: center;   /* FIXED */
    margin: 20px;
    padding-bottom:40px;
}

/* Class Selector */
.card {
    background-color: green;
    padding: 6px;         /* FIXED */
    margin: 10px auto;
    width: 50px;
    border: 20px solid black;
}

/* Group Selector */
h2, p {
    color: rgb(0, 255, 42);
}

/* Another Class Selector */
.name {
    font-size: 20px;      /* FIXED */
    margin-bottom: 10px;  /* FIXED */
}


info {
    font-size: 18px;
}

/* Headings & paragraphs */
h2, p {
    color: green;
}

/* Navigation */
nav ul {
    list-style: none;
    background: black;
    padding: 10px;
}

nav ul li {
    display: inline;
    margin:85px;
}

nav ul li a {
    color: white;
    text-decoration: none;
}

/* Image */
img {
    width: 160px;
    height: 180px;
    border-radius: 50%;
    border: 3px solid black; 
    margin-left:200;
    margin-right:700px;
   
}


